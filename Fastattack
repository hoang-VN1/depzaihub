spawn(function()
    while true do
        AttackInstance:Attack()
        AttackInstance:Attack()
        AttackInstance:Attack()
        task.wait(0.0001)  -- Gần như không chờ
    end
end)

-- Tấn công từ cả RemoteEvent nếu có
local oldFire = nil
if game:GetService("ReplicatedStorage"):FindFirstChild("RemoteEvent") then
    for _, remote in pairs(game:GetService("ReplicatedStorage"):GetChildren()) do
        if remote:IsA("RemoteEvent") and remote.Name:lower():find("attack") then
            oldFire = remote.FireServer
            remote.FireServer = function(self, ...)
                AttackInstance:Attack()
                return oldFire(self, ...)
            end
        end
    end
end

